<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Buyer Dashboard — My Dream Home</title><link rel="stylesheet" href="css/global.css"/><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous"/></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/find">Find Agent</a><a href="/change-password">Password</a><a href="/logout" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <div class="page-header"><h1>Welcome, <span class="text-red"><%= user.name %></span>!</h1><p>Your Buyer ID: #<%= user.id %></p></div>
  <section class="section">
    <div class="container">
      <div class="admin-grid">
        <div class="admin-card"><h3><i class="fas fa-search"></i> Browse Properties</h3><p class="text-light" style="margin-bottom:16px">Search and filter properties across cities</p><a href="/properties" class="btn btn-primary btn-sm"><i class="fas fa-building"></i> Browse</a></div>
        <div class="admin-card"><h3><i class="fas fa-lock"></i> Locked Properties (<%= locked.length %>)</h3><p class="text-light" style="margin-bottom:16px">Properties you've locked</p>
          <% if (locked.length > 0) { locked.forEach(function(p) { %><div style="padding:12px;background:var(--bg-alt);border-radius:8px;margin-bottom:8px"><strong>#<%= p.pid %></strong> — <%= p.title || p.street %> — ₹<%= p.price ? p.price.toLocaleString('en-IN') : 0 %></div><% }); } else { %><p class="text-light" style="font-size:0.9rem">No locked properties yet</p><% } %>
        </div>
        <div class="admin-card"><h3><i class="fas fa-receipt"></i> My Transactions (<%= transactions.length %>)</h3>
          <% if (transactions.length > 0) { transactions.forEach(function(t) { %><div style="padding:12px;background:var(--bg-alt);border-radius:8px;margin-bottom:8px"><strong>#<%= t.transaction_id %></strong> — Property #<%= t.pid %> — ₹<%= t.transaction_amount ? t.transaction_amount.toLocaleString('en-IN') : 0 %></div><% }); } else { %><p class="text-light" style="font-size:0.9rem">No transactions yet</p><% } %>
        </div>
      </div>
    </div>
  </section>
</body></html>
