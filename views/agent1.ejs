<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Agent Dashboard — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/find">Find Agent</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <div class="page-header"><h1>Agent <span class="text-red">Dashboard</span></h1><p>Welcome back! Manage your listings and clients.</p></div>
  <section class="section">
    <div class="container">
      <div class="admin-grid">
        <div class="admin-card"><h3><i class="fas fa-building"></i> My Properties</h3><p class="text-light" style="margin-bottom:16px">View and manage your property listings</p><a href="/showproperties" class="btn btn-primary btn-sm"><i class="fas fa-eye"></i> View Properties</a></div>
        <div class="admin-card"><h3><i class="fas fa-users"></i> My Clients</h3><p class="text-light" style="margin-bottom:16px">View your buyers and sellers</p><div class="data-buttons"><a href="/showbuyer" class="data-btn"><i class="fas fa-shopping-cart"></i> Buyers</a><a href="/showseller" class="data-btn"><i class="fas fa-store"></i> Sellers</a></div></div>
        <div class="admin-card"><h3><i class="fas fa-exchange-alt"></i> Transactions</h3><p class="text-light" style="margin-bottom:16px">View transaction history</p><a href="/showtransaction" class="btn btn-outline btn-sm"><i class="fas fa-receipt"></i> View All</a></div>
      </div>
    </div>
  </section>
</body></html>
