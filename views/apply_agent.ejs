<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Apply as Agent — My Dream Home</title><link rel="stylesheet" href="css/global.css"/><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous"/></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/about">About</a><a href="/contact">Contact</a><a href="/login" class="btn btn-primary btn-sm">Login</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <section class="section" style="padding-top:100px">
    <div class="container">
      <div class="form-card" style="max-width:600px">
        <h2>Become an <span class="text-red">Agent</span></h2>
        <p class="subtitle">Submit your application and our office team will review it. You can also visit our office in person at Dhanghata, UP - 272162.</p>
        <% if (success) { %><div style="background:#E8F5E9;color:#2E7D32;padding:14px;border-radius:12px;margin-bottom:20px;text-align:center;font-weight:600"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
        <form action="/apply-agent" method="POST">
          <div class="form-row"><div class="form-group"><label>Full Name</label><input type="text" name="name" required placeholder="Tushar Agrahari"/></div><div class="form-group"><label>City</label><input type="text" name="city" required placeholder="Mumbai"/></div></div>
          <div class="form-row"><div class="form-group"><label>Email</label><input type="email" name="email" required placeholder="you@email.com"/></div><div class="form-group"><label>Phone</label><input type="tel" name="phone" required placeholder="+91-9876543210"/></div></div>
          <div class="form-group"><label>Experience</label><input type="text" name="experience" placeholder="e.g., 3 years in real estate"/></div>
          <div class="form-group"><label>Why do you want to join?</label><textarea name="message" placeholder="Tell us about yourself..."></textarea></div>
          <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane"></i> Submit Application</button>
        </form>
        <div style="margin-top:24px;padding:20px;background:var(--bg-alt);border-radius:12px">
          <h4 style="margin-bottom:8px"><i class="fas fa-building" style="color:var(--primary);margin-right:6px"></i>Visit Our Office</h4>
          <p style="font-size:0.9rem;color:var(--text-light)">Dhanghata, Uttar Pradesh - 272162<br/>Email: tusharagrahari10@gmail.com<br/>Phone: +91 92191 31849</p>
        </div>
      </div>
    </div>
  </section>
</body></html>
