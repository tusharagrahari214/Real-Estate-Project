<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Add Property — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/back">Dashboard</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <section class="section" style="padding-top:100px">
    <div class="container">
      <a href="/back" class="back-link"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
      <div class="form-card" style="max-width:700px">
        <h2><i class="fas fa-home" style="color:var(--primary);margin-right:8px"></i>Add <span class="text-red">Property</span></h2>
        <p class="subtitle">Property ID will be auto-generated. Sellers can upload property images.</p>
        <form action="/insert_property" method="POST" enctype="multipart/form-data">
          <div class="form-group"><label>Property Title</label><input type="text" name="title" placeholder="Beautiful 2BHK in Andheri West" /></div>
          <div class="form-group"><label>Description</label><textarea name="description" placeholder="Describe the property — amenities, nearby landmarks, etc." style="min-height:80px"></textarea></div>
          <div class="form-row">
            <div class="form-group"><label>Price (₹)</label><input type="number" name="price" required placeholder="50000" /></div>
            <div class="form-group"><label>Area (sqft)</label><input type="number" name="area_sqft" placeholder="1200" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Listing Type</label><select name="listing_type" required><option value="rent">Rent</option><option value="buy">Buy</option></select></div>
            <div class="form-group"><label>Property Type</label><select name="property_type" required><option value="apartment">Apartment</option><option value="house">House</option><option value="villa">Villa</option><option value="flat">Flat</option><option value="hostel">Hostel</option><option value="pg">PG</option></select></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Bedrooms</label><select name="type" required><option value="1">1 BHK</option><option value="2">2 BHK</option><option value="3">3 BHK</option><option value="4">4 BHK</option><option value="5">5 BHK</option></select></div>
            <div class="form-group"><label>Furnished</label><select name="furnished"><option value="unfurnished">Unfurnished</option><option value="semi-furnished">Semi-Furnished</option><option value="furnished">Furnished</option></select></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>City</label><input type="text" name="city" required placeholder="Mumbai" /></div>
            <div class="form-group"><label>Street</label><input type="text" name="street" required placeholder="Andheri West" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Postal Code</label><input type="text" name="postalcode" placeholder="400053" /></div>
            <div class="form-group"><label>Year of Construction</label><input type="number" name="yoc" placeholder="2020" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Seller ID</label><input type="number" name="seller_id" placeholder="Auto-assigned" /></div>
            <div class="form-group"><label>Agent ID</label><input type="number" name="agent_id" placeholder="Assigned agent" /></div>
          </div>
          <div class="form-group">
            <label>Bachelor Allowed?</label>
            <select name="bachelor_allowed"><option value="true">Yes — Bachelors Welcome</option><option value="false">No — Families Only</option></select>
          </div>
          <div class="form-group">
            <label>Property Images</label>
            <input type="file" name="images" multiple accept="image/*" style="padding:10px;border:2px dashed var(--border);border-radius:var(--radius);width:100%;cursor:pointer" />
            <p style="font-size:0.8rem;color:var(--text-light);margin-top:6px">Upload up to 5 images (JPG, PNG)</p>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> List Property</button>
        </form>
      </div>
    </div>
  </section>
</body></html>
