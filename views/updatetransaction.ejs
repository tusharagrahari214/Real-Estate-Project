<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Add Transaction — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/back">Dashboard</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <section class="section" style="padding-top:100px">
    <div class="container">
      <a href="/back" class="back-link"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
      <div class="form-card" style="max-width:700px">
        <h2><i class="fas fa-receipt" style="color:var(--primary);margin-right:8px"></i>Add <span class="text-red">Transaction</span></h2>
        <p class="subtitle">Transaction ID will be auto-generated</p>
        <form action="/insertransaction" method="POST">
          <div class="form-row"><div class="form-group"><label>Property ID</label><input type="number" name="pid" required /></div><div class="form-group"><label>Seller ID</label><input type="number" name="seller_id" required /></div></div>
          <div class="form-row"><div class="form-group"><label>Buyer ID</label><input type="number" name="buyer_id" required /></div><div class="form-group"><label>Agent ID</label><input type="number" name="agent_id" required /></div></div>
          <div class="form-group"><label>Transaction Date</label><input type="date" name="transaction_date" required /></div>
          <div class="form-row"><div class="form-group"><label>Amount (₹)</label><input type="number" name="transaction_amount" required placeholder="5000000" /></div><div class="form-group"><label>Commission (₹)</label><input type="number" name="commission" placeholder="25000" /></div></div>
          <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Record Transaction</button>
        </form>
      </div>
    </div>
  </section>
</body></html>
