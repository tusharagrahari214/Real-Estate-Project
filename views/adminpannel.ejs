<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Admin Panel — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/dream">Queries</a><a href="/find">Find Agent</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <div class="page-header"><h1>Admin <span class="text-red">Dashboard</span></h1><p>Manage your platform data and operations</p></div>
  <section class="section">
    <div class="container">
      <% if (typeof message !== 'undefined' && message.trim()) { %>
        <div style="background:#E8F5E9;color:#2E7D32;padding:16px 20px;border-radius:12px;margin-bottom:32px;font-weight:600;text-align:center"><i class="fas fa-check-circle" style="margin-right:8px"></i><%= message %></div>
      <% } %>
      <div class="admin-grid">
        <div class="admin-card"><h3><i class="fas fa-database"></i> View Data</h3><p class="text-light" style="font-size:0.9rem;margin-bottom:16px">Browse all records stored in the database</p>
          <div class="data-buttons">
            <a href="/showagent" class="data-btn"><i class="fas fa-users"></i> Agents</a>
            <a href="/showproperties" class="data-btn"><i class="fas fa-building"></i> Properties</a>
            <a href="/showseller" class="data-btn"><i class="fas fa-store"></i> Sellers</a>
            <a href="/showbuyer" class="data-btn"><i class="fas fa-shopping-cart"></i> Buyers</a>
            <a href="/showtransaction" class="data-btn"><i class="fas fa-exchange-alt"></i> Transactions</a>
          </div>
        </div>
        <div class="admin-card"><h3><i class="fas fa-search"></i> Run Queries</h3><p class="text-light" style="font-size:0.9rem;margin-bottom:16px">Execute pre-built analytical queries</p>
          <a href="/dream" class="btn btn-primary btn-sm"><i class="fas fa-play"></i> Open Query Panel</a>
        </div>
        <div class="admin-card"><h3><i class="fas fa-plus-circle"></i> Quick Actions</h3><p class="text-light" style="font-size:0.9rem;margin-bottom:16px">Add new records to the database</p>
          <div class="data-buttons">
            <a href="/add_buyer" class="data-btn"><i class="fas fa-user-plus"></i> Add Buyer</a>
            <a href="/add_seller" class="data-btn"><i class="fas fa-user-plus"></i> Add Seller</a>
            <a href="/add_prop" class="data-btn"><i class="fas fa-home"></i> Add Property</a>
            <a href="/upt_tran" class="data-btn"><i class="fas fa-receipt"></i> Add Transaction</a>
          </div>
        </div>
      </div>
      <div class="admin-card" style="margin-top:24px"><h3><i class="fas fa-terminal"></i> Quick Search</h3><p class="text-light" style="font-size:0.9rem;margin-bottom:16px">Type a command to search data (e.g., "show agents", "show properties")</p>
        <form action="/query" method="POST" style="display:flex;gap:12px">
          <input type="text" name="query" placeholder='Try: show agents, show properties, show buyers...' style="flex:1;padding:14px 18px;border:2px solid var(--border);border-radius:var(--radius);font-size:1rem" />
          <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Search</button>
        </form>
      </div>
    </div>
  </section>
</body></html>
