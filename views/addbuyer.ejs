<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Add Buyer — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/back">Dashboard</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <section class="section" style="padding-top:100px">
    <div class="container">
      <a href="/back" class="back-link"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
      <div class="form-card">
        <h2><i class="fas fa-user-plus" style="color:var(--primary);margin-right:8px"></i>Add <span class="text-red">Buyer</span></h2>
        <p class="subtitle">Buyer ID will be auto-generated</p>
        <form action="/insert_buyer" method="POST">
          <div class="form-row"><div class="form-group"><label>First Name</label><input type="text" name="fname" required /></div><div class="form-group"><label>Last Name</label><input type="text" name="lname" /></div></div>
          <div class="form-group"><label>Phone Number</label><input type="tel" name="phoneno" required placeholder="+91-9876543210" /></div>
          <div class="form-group"><label>Email</label><input type="email" name="email" placeholder="buyer@email.com" /></div>
          <div class="form-group"><label>Agent ID</label><input type="number" name="agent_id" placeholder="Assigned agent ID" /></div>
          <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Add Buyer</button>
        </form>
      </div>
    </div>
  </section>
</body></html>
