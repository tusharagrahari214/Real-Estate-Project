<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Add Record — My Dream Home</title><link rel="stylesheet" href="/css/global.css"/><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous"/></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="/images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/admin-dashboard">Dashboard</a><a href="/logout" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <section class="section" style="padding-top:100px">
    <div class="container">
      <a href="/admin-dashboard" class="back-link"><i class="fas fa-arrow-left"></i> Back</a>
      <div class="form-card" style="max-width:700px">
        <% if (collection === 'buyer') { %>
          <h2>Add <span class="text-red">Buyer</span></h2><p class="subtitle">ID auto-generated</p>
          <form action="/admin-add/buyer" method="POST">
            <div class="form-row"><div class="form-group"><label>First Name</label><input type="text" name="fname" required/></div><div class="form-group"><label>Last Name</label><input type="text" name="lname"/></div></div>
            <div class="form-group"><label>Phone</label><input type="tel" name="phoneno" required/></div>
            <div class="form-group"><label>Email</label><input type="email" name="email"/></div>
            <div class="form-group"><label>Password</label><input type="password" name="password"/></div>
            <div class="form-group"><label>Agent ID</label><input type="number" name="agent_id"/></div>
            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Add Buyer</button>
          </form>
        <% } else if (collection === 'seller') { %>
          <h2>Add <span class="text-red">Seller</span></h2><p class="subtitle">ID auto-generated</p>
          <form action="/admin-add/seller" method="POST">
            <div class="form-row"><div class="form-group"><label>First Name</label><input type="text" name="fname" required/></div><div class="form-group"><label>Last Name</label><input type="text" name="lname"/></div></div>
            <div class="form-group"><label>Phone</label><input type="tel" name="phoneno" required/></div>
            <div class="form-group"><label>Email</label><input type="email" name="email"/></div>
            <div class="form-group"><label>Password</label><input type="password" name="password"/></div>
            <div class="form-group"><label>UPI ID</label><input type="text" name="upi_id" placeholder="name@upi"/></div>
            <div class="form-group"><label>Agent ID</label><input type="number" name="agent_id"/></div>
            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Add Seller</button>
          </form>
        <% } else if (collection === 'property') { %>
          <h2>Add <span class="text-red">Property</span></h2><p class="subtitle">Admin-added properties are auto-approved</p>
          <form action="/admin-add/property" method="POST" enctype="multipart/form-data">
            <div class="form-group"><label>Title</label><input type="text" name="title" required/></div>
            <div class="form-group"><label>Description</label><textarea name="description"></textarea></div>
            <div class="form-row"><div class="form-group"><label>Price</label><input type="number" name="price" required/></div><div class="form-group"><label>Area (sqft)</label><input type="number" name="area_sqft"/></div></div>
            <div class="form-row"><div class="form-group"><label>Listing Type</label><select name="listing_type"><option value="rent">Rent</option><option value="buy">Buy</option></select></div><div class="form-group"><label>Property Type</label><select name="property_type"><option value="apartment">Apartment</option><option value="house">House</option><option value="villa">Villa</option><option value="flat">Flat</option><option value="hostel">Hostel</option><option value="pg">PG</option></select></div></div>
            <div class="form-row"><div class="form-group"><label>Bedrooms</label><input type="number" name="bedrooms" required/></div><div class="form-group"><label>Furnished</label><select name="furnished"><option value="unfurnished">Unfurnished</option><option value="semi-furnished">Semi</option><option value="furnished">Furnished</option></select></div></div>
            <div class="form-row"><div class="form-group"><label>City</label><input type="text" name="city" required/></div><div class="form-group"><label>Street</label><input type="text" name="street" required/></div></div>
            <div class="form-row"><div class="form-group"><label>Postal Code</label><input type="text" name="postalcode"/></div><div class="form-group"><label>Year Built</label><input type="number" name="yoc"/></div></div>
            <div class="form-row"><div class="form-group"><label>Seller ID</label><input type="number" name="seller_id"/></div><div class="form-group"><label>Agent ID</label><input type="number" name="agent_id"/></div></div>
            <div class="form-group"><label>Bachelor Allowed</label><select name="bachelor_allowed"><option value="true">Yes</option><option value="false">No</option></select></div>
            <div class="form-group"><label>Images</label><input type="file" name="images" multiple accept="image/*" style="padding:10px;border:2px dashed var(--border);border-radius:var(--radius);width:100%"/></div>
            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Add Property</button>
          </form>
        <% } else if (collection === 'transaction') { %>
          <h2>Add <span class="text-red">Transaction</span></h2><p class="subtitle">ID auto-generated</p>
          <form action="/admin-add/transaction" method="POST">
            <div class="form-row"><div class="form-group"><label>Property ID</label><input type="number" name="pid" required/></div><div class="form-group"><label>Seller ID</label><input type="number" name="seller_id" required/></div></div>
            <div class="form-row"><div class="form-group"><label>Buyer ID</label><input type="number" name="buyer_id" required/></div><div class="form-group"><label>Agent ID</label><input type="number" name="agent_id" required/></div></div>
            <div class="form-group"><label>Date</label><input type="date" name="transaction_date" required/></div>
            <div class="form-row"><div class="form-group"><label>Amount</label><input type="number" name="transaction_amount" required/></div><div class="form-group"><label>Commission</label><input type="number" name="commission"/></div></div>
            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Record</button>
          </form>
        <% } %>
      </div>
    </div>
  </section>
</body></html>
