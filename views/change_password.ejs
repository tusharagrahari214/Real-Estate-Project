<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Change Password — My Dream Home</title><link rel="stylesheet" href="css/global.css"/><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous"/></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/logout" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <div class="auth-page">
    <div class="auth-card">
      <h2>Change <span class="text-red">Password</span></h2>
      <p class="subtitle">Update your account password</p>
      <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
      <% if (success) { %><div style="background:#E8F5E9;color:#2E7D32;padding:12px;border-radius:12px;margin-bottom:20px;text-align:center;font-size:0.9rem"><%= success %></div><% } %>
      <form action="/change-password" method="POST">
        <div class="form-group"><label>Current Password</label><input type="password" name="old_password" required/></div>
        <div class="form-group"><label>New Password</label><input type="password" name="new_password" required minlength="4"/></div>
        <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-key"></i> Update Password</button>
      </form>
    </div>
  </div>
</body></html>
