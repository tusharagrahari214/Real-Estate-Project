<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us — My Dream Home</title>
  <link rel="stylesheet" href="css/global.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    crossorigin="anonymous" />
</head>

<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="logo"><img src="images/logo.jpg" alt="Logo" />My Dream<span>Home</span></a>
      <div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a
          href="/about">About</a><a href="/contact" class="active">Contact</a><a href="/find">Find Agent</a><a
          href="/register" class="btn btn-primary btn-sm">Get Started</a></div>
      <div class="hamburger"
        onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')">
        <span></span><span></span><span></span></div>
    </div>
  </nav>

  <div class="page-header">
    <h1>Contact <span class="text-red">Us</span></h1>
    <p>We'd love to hear from you</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="gap:64px;align-items:start">
        <div class="form-card" style="max-width:100%">
          <h2>Send us a <span class="text-red">Message</span></h2>
          <p class="subtitle">Fill the form and our team will get back to you within 24 hours.</p>
          <form action="/contact" method="POST">
            <div class="form-row">
              <div class="form-group"><label>Your Name</label><input type="text" name="name" required
                  placeholder="John Doe" /></div>
              <div class="form-group"><label>Phone</label><input type="tel" name="phone" required
                  placeholder="+91-9876543210" /></div>
            </div>
            <div class="form-group"><label>Email</label><input type="email" name="email" required
                placeholder="you@email.com" /></div>
            <div class="form-group"><label>Message</label><textarea name="message" required
                placeholder="Tell us how we can help you..."></textarea></div>
            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane"></i> Send
              Message</button>
          </form>
        </div>
        <div>
          <div style="margin-bottom:40px">
            <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:20px">Get in Touch</h3>
            <div style="display:flex;gap:16px;align-items:start;margin-bottom:24px">
              <div
                style="width:48px;height:48px;border-radius:12px;background:rgba(229,57,53,0.1);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0">
                <i class="fas fa-envelope" style="font-size:1.1rem"></i></div>
              <div>
                <p style="font-weight:600;margin-bottom:4px">Email</p><a href="mailto:tusharagrahari10@gmail.com"
                  class="text-light" style="font-size:0.9rem">tusharagrahari10@gmail.com</a>
              </div>
            </div>
            <div style="display:flex;gap:16px;align-items:start;margin-bottom:24px">
              <div
                style="width:48px;height:48px;border-radius:12px;background:rgba(229,57,53,0.1);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0">
                <i class="fas fa-phone" style="font-size:1.1rem"></i></div>
              <div>
                <p style="font-weight:600;margin-bottom:4px">Phone</p>
                <p class="text-light" style="font-size:0.9rem">+91 92191 31849</p>
              </div>
            </div>
            <div style="display:flex;gap:16px;align-items:start;margin-bottom:24px">
              <div
                style="width:48px;height:48px;border-radius:12px;background:rgba(229,57,53,0.1);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0">
                <i class="fas fa-map-marker-alt" style="font-size:1.1rem"></i></div>
              <div>
                <p style="font-weight:600;margin-bottom:4px">Office</p>
                <p class="text-light" style="font-size:0.9rem">Gorakhpur, Uttar Pradesh - 273001</p>
              </div>
            </div>
          </div>
          <div style="margin-top:32px">
            <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:16px">Follow Us</h3>
            <div class="footer-social">
              <a href="https://www.facebook.com/tusharagrahari214/" target="_blank"
                style="background:rgba(229,57,53,0.1);color:var(--primary)"><i class="fab fa-facebook-f"></i></a>
              <a href="https://x.com/tusharagrahari1" target="_blank"
                style="background:rgba(229,57,53,0.1);color:var(--primary)"><i class="fab fa-twitter"></i></a>
              <a href="https://www.instagram.com/_tushar_agrahari_214/" target="_blank"
                style="background:rgba(229,57,53,0.1);color:var(--primary)"><i class="fab fa-instagram"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo"><img src="images/logo.jpg" alt="Logo" />My Dream<span style="color:var(--primary)">Home</span>
        </div>
        <p>India's trusted property platform.</p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/properties?type=buy">Buy</a></li>
          <li><a href="/properties?type=rent">Rent</a></li>
        </ul>
      </div>
      <div>
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:tusharagrahari10@gmail.com"><i class="fas fa-envelope"
                style="margin-right:6px"></i>tusharagrahari10@gmail.com</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">&copy; 2024 My Dream Home. Built by Tushar Agrahari.</div>
  </footer>
</body>

</html>