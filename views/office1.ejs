<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Office Panel — My Dream Home</title><link rel="stylesheet" href="css/global.css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" /></head>
<body>
  <nav class="navbar"><div class="nav-container"><a href="/" class="logo"><img src="images/logo.jpg" alt="Logo"/>My Dream<span>Home</span></a><div class="nav-links" id="navLinks"><a href="/">Home</a><a href="/properties">Properties</a><a href="/find">Find Agent</a><a href="/" class="btn btn-primary btn-sm">Logout</a></div><div class="hamburger" onclick="document.getElementById('navLinks').classList.toggle('open');this.classList.toggle('active')"><span></span><span></span><span></span></div></div></nav>
  <div class="page-header"><h1>Office <span class="text-red">Management</span></h1><p>Manage agents, credentials & view data</p></div>
  <section class="section">
    <div class="container">
      <% if (typeof message1 !== 'undefined' && message1.trim()) { %><div style="background:#E8F5E9;color:#2E7D32;padding:14px;border-radius:12px;margin-bottom:20px;text-align:center;font-weight:600"><%= message1 %></div><% } %>
      <% if (typeof message2 !== 'undefined' && message2.trim()) { %><div style="background:#FFF3E0;color:#E65100;padding:14px;border-radius:12px;margin-bottom:20px;text-align:center;font-weight:600"><%= message2 %></div><% } %>
      <% if (typeof message3 !== 'undefined' && message3.trim()) { %><div style="background:#E3F2FD;color:#1565C0;padding:14px;border-radius:12px;margin-bottom:20px;text-align:center;font-weight:600"><%= message3 %></div><% } %>
      <div class="admin-grid">
        <div class="admin-card">
          <h3><i class="fas fa-user-plus"></i> Add Agent</h3>
          <form action="/addagent" method="post">
            <div class="form-row"><div class="form-group"><label>First Name</label><input type="text" name="fname" required /></div><div class="form-group"><label>Last Name</label><input type="text" name="lname" /></div></div>
            <div class="form-row"><div class="form-group"><label>City</label><input type="text" name="city" /></div><div class="form-group"><label>Street</label><input type="text" name="street" /></div></div>
            <div class="form-row"><div class="form-group"><label>Postal Code</label><input type="text" name="postalcode" /></div><div class="form-group"><label>Phone</label><input type="text" name="phoneno" required /></div></div>
            <div class="form-group"><label>Email</label><input type="email" name="email" /></div>
            <button type="submit" class="btn btn-primary btn-block btn-sm"><i class="fas fa-plus"></i> Add Agent</button>
          </form>
        </div>
        <div class="admin-card">
          <h3><i class="fas fa-user-minus"></i> Remove Agent</h3>
          <form action="/deleteagent" method="post">
            <div class="form-group"><label>Agent ID</label><input type="number" name="agentid" required placeholder="Enter Agent ID" /></div>
            <button type="submit" class="btn btn-outline btn-block btn-sm"><i class="fas fa-trash"></i> Remove Agent</button>
          </form>
          <div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--border)">
            <h3 style="font-size:1.1rem;margin-bottom:16px"><i class="fas fa-key" style="color:var(--primary);margin-right:6px"></i> Agent Credentials</h3>
            <form action="/credential" method="post">
              <div class="form-group"><label>Username</label><input type="text" name="username" required placeholder="@AgentName" /></div>
              <div class="form-group"><label>Password</label><input type="password" name="password" required /></div>
              <button type="submit" class="btn btn-dark btn-block btn-sm"><i class="fas fa-lock"></i> Assign Credentials</button>
            </form>
          </div>
        </div>
        <div class="admin-card">
          <h3><i class="fas fa-database"></i> View Data</h3>
          <p class="text-light" style="font-size:0.9rem;margin-bottom:16px">Browse database records</p>
          <div class="data-buttons" style="flex-direction:column">
            <a href="/showagent" class="data-btn" style="text-align:center"><i class="fas fa-users"></i> All Agents</a>
            <a href="/showproperties" class="data-btn" style="text-align:center"><i class="fas fa-building"></i> All Properties</a>
            <a href="/showseller" class="data-btn" style="text-align:center"><i class="fas fa-store"></i> All Sellers</a>
            <a href="/showbuyer" class="data-btn" style="text-align:center"><i class="fas fa-shopping-cart"></i> All Buyers</a>
            <a href="/showtransaction" class="data-btn" style="text-align:center"><i class="fas fa-exchange-alt"></i> Transactions</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</body></html>
